@model List<VeriWork_Admin.Application.Models.MonthlyAuditLogsViewModel>

@{
    ViewData["Title"] = "Audit Logs";
    Layout = "_Layout";
}

<div class="audit-log-page" id="mainContent">
    <div class="page-header">
        <h1>Audit Logs</h1>
        <a asp-action="Dashboard" asp-controller="User" class="btn-back">
            &leftarrow; Back to Directory
        </a>
    </div>

    @foreach (var month in Model)
    {
        <div class="log-section">
            <div class="log-section-header">
                <h4>@month.Month</h4>
                <a asp-action="DownloadMonthlyReport" asp-route-month="@month.Month" class="btn-download">Download</a>
            </div>

            <table class="audit-table">
                <thead>
                <tr>
                    <th>Admin Email</th>
                    <th>Action Type</th>
                    <th>Description</th>
                    <th>Timestamp</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var log in month.Logs)
                {
                    <tr>
                        <td>@log.AdminEmail</td>
                        <td>@log.ActionType</td>
                        <td>@log.Description</td>
                        <td>@log.ActionDate.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
