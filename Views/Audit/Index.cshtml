@{
    ViewData["Title"] = "Audit Log";
    Layout = "_Layout";
}

<style>
    .audit-log-page {
        font-family: 'Inter', sans-serif;
    }

    /* Page Header */
    .page-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .page-header h1 {
        font-family: 'Unbounded', sans-serif;
        font-size: 30px;
        font-weight: 700;
        color: #171A1F;
        margin: 0;
    }
    .btn-back {
        height: 40px;
        padding: 0 16px;
        background: rgba(16, 67, 135, 0.7);
        color: #FFFFFF;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(16, 67, 135, 1);
        color: #FFFFFF;
    }

    /* Filter Bar */
    .filter-bar {
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0 0 1px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.1);
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .filter-input {
        width: 590px;
        height: 40px;
        padding: 0 12px;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        font-size: 14px;
    }
    .btn-apply-filters {
        height: 40px;
        padding: 0 24px;
        background: #0F74C7;
        color: #FFFFFF;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        font-size: 14px;
    }
     .btn-apply-filters:hover {
        background: #0A4D84;
    }

    /* Log Section */
    .log-section {
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0 0 1px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }
    .log-section-header {
        padding: 16px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #DEE1E6;
    }
    .log-section-header h4 {
        font-family: 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 500;
        color: #171A1F;
        margin: 0;
    }
    .btn-download {
        height: 36px;
        padding: 0 16px;
        background: #FFFFFF;
        color: #0F74C7;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .btn-download:hover {
        background: #F9FAFB;
    }

    /* Audit Table */
    .audit-table {
        width: 100%;
        border-collapse: collapse;
    }
    .audit-table th, .audit-table td {
        padding: 14px 24px;
        text-align: left;
        border-bottom: 1px solid #DEE1E6;
        font-size: 14px;
    }
    .audit-table thead th {
        font-weight: 600;
        color: #565D6D;
    }
    .audit-table tbody td {
        color: #171A1F;
    }
    .audit-table tbody tr:last-child td {
        border-bottom: none;
    }

    /* Status Tags */
    .status-tag {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 500;
    }
    .status-approved {
        background-color: #D1FAE5;
        color: #065F46;
    }
    .status-pending {
        background-color: #FFEDD5;
        color: #9A3412;
    }
    .status-rejected {
        background-color: #FEE2E2;
        color: #991B1B;
    }
</style>

<div class="audit-log-page">
    <div class="page-header">
        <h1>Audit Log</h1>
        <a asp-action="Dashboard" asp-controller="User" class="btn-back">
            &leftarrow; Back to Directory
        </a>
    </div>

    <div class="filter-bar">
        <input type="text" class="filter-input" placeholder="Filter by Employee ID, Action Type, or Verifier">
        <button class="btn-apply-filters">Apply Filters</button>
