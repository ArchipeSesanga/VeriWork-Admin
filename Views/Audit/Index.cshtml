

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}
<div class="text-start d-flex justify-content-start  gap-5 pt-2">
    <h2>Audit Logs</h2>
    <a class="btn btn-primary" asp-controller="User" asp-action="Dashboard">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
        </svg>
        Back to Directory
    </a>
</div>

<div class="container p-5">
    <div class="row">
        <div class="col-md-12">
            <form class="d-flex">
                <div class="input-group">
                    <input class="form-control form-control-lg" type="search" placeholder="Filter by employee's ID" aria-label="Search">
                    <button class="btn btn-primary px-4 " type="submit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                        </svg> <span class="px-2">Apply Filter</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* table *@
