@{
    ViewData["Title"] = "Audit Log";
    Layout = "_Layout";
}

<style>
    .audit-log-page {
        font-family: 'Inter', sans-serif;
        /* --- NEW: Added for blur transition --- */
        transition: filter 0.3s ease-in-out;
    }

    /* --- NEW: Class to apply blur --- */
    .blurred {
        filter: blur(5px);
        pointer-events: none; /* Prevents interaction with blurred content */
    }

    /* Page Header */
    .page-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .page-header h1 {
        font-family: 'Unbounded', sans-serif;
        font-size: 30px;
        font-weight: 700;
        color: #171A1F;
        margin: 0;
    }
    .btn-back {
        height: 40px;
        padding: 0 16px;
        background: rgba(16, 67, 135, 0.7);
        color: #FFFFFF;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(16, 67, 135, 1);
        color: #FFFFFF;
    }

    /* Filter Bar */
    .filter-bar {
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0 0 1px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.1);
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .filter-input {
        width: 590px;
        height: 40px;
        padding: 0 12px;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        font-size: 14px;
    }
    .btn-apply-filters {
        height: 40px;
        padding: 0 24px;
        background: #0F74C7;
        color: #FFFFFF;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        font-size: 14px;
    }
    .btn-apply-filters:hover {
        background: #0A4D84;
    }

    /* Log Section */
    .log-section {
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0 0 1px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }
    .log-section-header {
        padding: 16px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #DEE1E6;
    }
    .log-section-header h4 {
        font-family: 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 500;
        color: #171A1F;
        margin: 0;
    }
    .btn-download {
        height: 36px;
        padding: 0 16px;
        background: #FFFFFF;
        color: #0F74C7;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .btn-download:hover {
        background: #F9FAFB;
    }

    /* Audit Table */
    .audit-table {
        width: 100%;
        border-collapse: collapse;
    }
    .audit-table th, .audit-table td {
        padding: 14px 24px;
        text-align: left;
        border-bottom: 1px solid #DEE1E6;
        font-size: 14px;
    }
    .audit-table thead th {
        font-weight: 600;
        color: #565D6D;
    }
    .audit-table tbody td {
        color: #171A1F;
    }
    .audit-table tbody tr:last-child td {
        border-bottom: none;
    }

    /* Status Tags */
    .status-tag {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 500;
    }
    .status-approved {
        background-color: #D1FAE5;
        color: #065F46;
    }
    .status-pending {
        background-color: #FFEDD5;
        color: #9A3412;
    }
    .status-rejected {
        background-color: #FEE2E2;
        color: #991B1B;
    }
    
    /* --- NEW: POP-UP STYLES --- */
    .popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: none; /* Hidden by default */
        justify-content: center;
        align-items: center;
        z-index: 1050;
    }
    .popup-box {
        width: 448px;
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0px 8.5px 13.75px rgba(23, 26, 31, 0.4), 0px 0px 2px rgba(23, 26, 31, 0.08);
        text-align: center;
        padding: 32px;
        display: none; /* Hidden by default */
    }
    .popup-icon {
        width: 64px;
        height: 64px;
        color: #B0251A; /* Red color from image */
        margin: 0 auto 16px;
    }
    .popup-title {
        font-family: 'Inter', sans-serif;
        font-size: 30px;
        font-weight: 700;
        color: #171A1F;
        margin: 0 0 8px 0;
    }
    .popup-text {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        color: #565D6D;
        margin-bottom: 2rem;
    }
    .btn-popup-action {
        width: 100%;
        height: 40px;
        background: #104387;
        color: #FFFFFF;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }
    .btn-popup-action:hover {
        background: #0A2A55;
    }

</style>

<div class="audit-log-page" id="mainContent">
    <div class="page-header">
        <h1>Audit Log</h1>
        <a asp-action="Dashboard" asp-controller="User" class="btn-back">
            &leftarrow; Back to Directory
        </a>
    </div>

    <div class="filter-bar">
        <input type="text" class="filter-input" placeholder="Filter by Employee ID, Action Type, or Verifier">
        <button class="btn-apply-filters">Apply Filters</button>
    </div>

    <div class="log-section">
        <div class="log-section-header">
            <h4>August 2024</h4>
            <button class="btn-download">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                    <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                </svg>
                Download
            </button>
        </div>
        <table class="audit-table">
            <thead>
                <tr>
                    <th>Employee ID</th>
                    <th>Action Type</th>
                    <th>Timestamp</th>
                    <th>Verified By</th>
                    <th>Status</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>EMP001</td>
                    <td>Document Upload</td>
                    <td>2024-08-28 10:30 AM</td>
                    <td>Admin A</td>
                    <td><span class="status-tag status-approved">Approved</span></td>
                    <td>Passport scanned and uploaded.</td>
                </tr>
                <tr>
                    <td>EMP003</td>
                    <td>Verification Request</td>
                    <td>2024-08-27 02:15 PM</td>
                    <td>Admin B</td>
                    <td><span class="status-tag status-pending">Pending</span></td>
                    <td>New hire onboarding documents.</td>
                </tr>
                <tr>
                    <td>EMP002</td>
                    <td>Document Review</td>
                    <td>2024-08-26 09:00 AM</td>
                    <td>Admin A</td>
                    <td><span class="status-tag status-rejected">Rejected</span></td>
                    <td>Incorrect ID format, required resubmission.</td>
                </tr>
                 <tr>
                    <td>EMP005</td>
                    <td>Verification Completion</td>
                    <td>2024-08-25 04:45 PM</td>
                    <td>Admin C</td>
                    <td><span class="status-tag status-approved">Approved</span></td>
                    <td>All documents validated successfully.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="popup-overlay" id="popupOverlay">
    
    <div class="popup-box" id="inProgressPopup">
        <div class="popup-icon">
             <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
             </svg>
        </div>
        <h2 class="popup-title">Download in progress...</h2>
        <p class="popup-text">Please wait for your file to be retrieved from the database.</p>
    </div>

    <div class="popup-box" id="successfulPopup">
        <div class="popup-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
        </div>
        <h2 class="popup-title">Download Successful!</h2>
        <button class="btn-popup-action" id="closePopupButton">Back to Audit Log</button>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const downloadButtons = document.querySelectorAll('.btn-download');
            const overlay = document.getElementById('popupOverlay');
            const mainContent = document.getElementById('mainContent');
            const inProgressPopup = document.getElementById('inProgressPopup');
            const successfulPopup = document.getElementById('successfulPopup');
            const closeButton = document.getElementById('closePopupButton');

            function openPopup() {
                // Show the "in progress" state first
                overlay.style.display = 'flex';
                inProgressPopup.style.display = 'block';
                successfulPopup.style.display = 'none';
                mainContent.classList.add('blurred');

                // Simulate a download process
                setTimeout(function () {
                    inProgressPopup.style.display = 'none';
                    successfulPopup.style.display = 'block';
                }, 2500); // 2.5 second delay
            }

            function closePopup() {
                overlay.style.display = 'none';
                mainContent.classList.remove('blurred');
            }

            // Attach event listener to all download buttons
            downloadButtons.forEach(button => {
                button.addEventListener('click', function(event) {
                    event.preventDefault(); // Prevent default button action
                    openPopup();
                });
            });

            // Attach event listener to the close button
            closeButton.addEventListener('click', closePopup);
        });
    </script>
}