<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VeriWork_Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/VeriWork_Admin.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@200..900&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; margin: 0; background: #F8F9FA; }
        .app-header { width: 100%; height: 64px; background: #104387; box-shadow: 0px 0px 1px #171a1fD, 0px 0px 2px #171a1f14; display: flex; align-items: center; justify-content: space-between; padding: 0 27px; box-sizing: border-box; flex-shrink: 0; position: relative; z-index: 1060; }
        .header-left-section { display: flex; align-items: center; gap: 20px; }
        .dashboard-header-logo { width: 61px; height: 38px; object-fit: contain; }
        .header-brand-name { font-family: 'Unbounded', sans-serif; font-size: 24px; line-height: 36px; font-weight: 600; color: #FFFFFFFF; }
        .btn-sign-out { height: 40px; padding: 0 12px; display: flex; align-items: center; justify-content: center; font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 500; color: #FFFFFF; background: #B0251A; border: none; border-radius: 6px; gap: 8px; text-decoration: none; cursor: pointer; }
        .btn-sign-out:hover { background: #8e1f16; color: #FFFFFF; }
        .btn-sign-out .icon { width: 16px; height: 16px; fill: #FFFFFF; }
        .app-layout { display: flex; flex: 1; transition: filter 0.3s ease-in-out; }
        .blurred { filter: blur(5px); pointer-events: none; }
        .left-panel { width: 254px; min-height: calc(100vh - 64px - 52px); padding: 24px 16px; box-sizing: border-box; flex-shrink: 0; background-image: linear-gradient(180deg, rgba(243, 244, 246, 0.9) 0%, rgba(229, 231, 235, 0.9) 100%), url('@Url.Content("~/images/left_panel_background.png")'); background-position: center, center; background-repeat: no-repeat, no-repeat; background-size: cover, cover; }
        .admin-panel-text { font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 600; color: #565D6D; margin-bottom: 20px; padding-left: 8px; }
        .panel-menu { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
        .panel-menu-item a { display: flex; align-items: center; gap: 8px; padding: 8px; text-decoration: none; border-radius: 6px; font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 500; color: #565D6D; transition: background-color 0.2s ease-in-out; }
        .panel-menu-item a:hover { background-color: rgba(224, 226, 231, 0.8); }
        .panel-menu-item a.selected { background: #FFFFFF; color: #1E2128; }
        .panel-menu-item a.selected:hover { background: #FFFFFF; }
        .panel-menu-item a .icon { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; padding: 30px 45px; overflow-y: auto; }
        .app-footer { width: 100%; height: 52px; background: #FFFFFF; box-shadow: 0px -1px 2px rgba(0, 0, 0, 0.05); display: flex; align-items: center; justify-content: space-between; padding: 0 45px; box-sizing: border-box; flex-shrink: 0; transition: filter 0.3s ease-in-out; }
        .footer-text { font-family: 'Unbounded', sans-serif; font-size: 14px; color: #171A1F; }
        .footer-text a { color: #104387; text-decoration: none; }
        .footer-text a:hover { text-decoration: underline; }
        .footer-social-icons { display: flex; gap: 20px; }
        .footer-social-icons .icon { width: 20px; height: 20px; fill: #171A1F; transition: fill 0.2s ease; }
        .footer-social-icons a:hover .icon { fill: #104387; }
        
        /* Logout Pop-up Styles */
        .popup-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; display: none; justify-content: center; align-items: center; z-index: 1050; }
        .popup-box { width: 448px; background: #FFFFFF; border-radius: 10px; box-shadow: 0px 8.5px 13.75px rgba(23, 26, 31, 0.4), 0px 0px 2px rgba(23, 26, 31, 0.08); text-align: center; padding: 32px; }
        .popup-icon { width: 64px; height: 64px; color: #B0251A; margin: 0 auto 16px; }
        .popup-title { font-family: 'Inter', sans-serif; font-size: 30px; font-weight: 700; color: #171A1F; margin: 0 0 8px 0; }
        .popup-text { font-family: 'Inter', sans-serif; font-size: 16px; color: #565D6D; margin-bottom: 3rem; }
        .popup-actions { display: flex; gap: 16px; }
        .btn-popup { width: 100%; height: 40px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; border: none; border-radius: 6px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
        .btn-popup-confirm { background: #B0251A; color: #FFFFFF; }
        .btn-popup-confirm:hover { background: #7B1912; color: #FFFFFF; }
        .btn-popup-cancel { background: #104387; color: #FFFFFF; }
        .btn-popup-cancel:hover { background: #0A2A55; }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <header class="app-header">
        <div class="header-left-section">
            <img src="~/images/white_logo.png" alt="VeriWork_Admin Logo" class="dashboard-header-logo" />
            <span class="header-brand-name">VeriWork</span>
        </div>
        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn-sign-out">
                <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 2h8A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 5 12.5v-2a.5.5 0 0 1 1 0z"/>
                    <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708z"/>
                </svg>
                Logout
            </button>
            @Html.AntiForgeryToken()
        </form>
    </header>

    <div class="app-layout" id="mainAppLayout">
        <nav class="left-panel">
            <h6 class="admin-panel-text">ADMIN PANEL</h6>
            <ul class="panel-menu">
                <li class="panel-menu-item">
                    <a class="@(currentController == "User" && currentAction == "Dashboard" ? "selected" : "")" asp-controller="User" asp-action="Dashboard">
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                           <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4M3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707M2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10m9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5m.754-4.246a.39.39 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.39.39 0 0 0-.029-.518z"/>
                           <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A8 8 0 0 1 0 10m8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3"/>
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li class="panel-menu-item">
                    <a class="@(currentController == "Audit" ? "selected" : "")" asp-controller="Audit" asp-action="Index">
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                           <path d="m14.12 10.163 1.715.858c.22.11.22.424 0 .534L8.267 15.34a.6.6 0 0 1-.534 0L.165 11.555a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0l5.317-2.66zM7.733.063a.6.6 0 0 1 .534 0l7.568 3.784a.3.3 0 0 1 0 .535L8.267 8.165a.6.6 0 0 1-.534 0L.165 4.382a.299.299 0 0 1 0-.535z"/>
                           <path d="m14.12 6.576 1.715.858c.22.11.22.424 0 .534l-7.568 3.784a.6.6 0 0 1-.534 0L.165 7.968a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0z"/>
                        </svg>
                        Audit Logs
                    </a>
                </li>
            </ul>
        </nav>

        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer" id="mainAppFooter">
        <div class="footer-text">
            &copy; 2025 - VeriWork_Admin - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        <div class="footer-social-icons">
             <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"></svg></a>
             <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"></svg></a>
             <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"></svg></a>
        </div>
    </footer>

    <div class="popup-overlay" id="logoutPopupOverlay">
        <div class="popup-box">
            <div class="popup-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                    <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-1.057 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286zm1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/>
                </svg>
            </div>
            <h2 class="popup-title">Are you sure?</h2>
            <p class="popup-text">You are about to log out of your account.</p>
            <div class="popup-actions">
                <button class="btn-popup btn-popup-cancel" id="cancelLogoutButton">Cancel</button>
                <a asp-action="Login" asp-controller="Auth" class="btn-popup btn-popup-confirm">Logout</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

