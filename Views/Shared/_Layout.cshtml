<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VeriWork_Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/VeriWork_Admin.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@200..900&family=Inter:wght@400;500&display=swap" rel="stylesheet">

    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            background: #F8F9FA;
        }

        /* Header */
        .app-header {
            width: 100%;
            height: 64px;
            background: #104387;
            box-shadow: 0px 0px 1px #171a1fD, 0px 0px 2px #171a1f14;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 27px;
            box-sizing: border-box;
            flex-shrink: 0;
        }

        .header-left-section {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .dashboard-header-logo {
            width: 61px;
            height: 38px;
            object-fit: contain;
        }

        /* --- MODIFIED: Header Menu CSS --- */
        .header-menu {
            display: flex;
            align-items: center;
        }

        .header-brand-name {
            font-family: 'Unbounded', sans-serif;
            font-size: 24px;
            line-height: 36px;
            font-weight: 600;
            color: #FFFFFFFF;
        }

        /* Sign out button */
        .btn-sign-out {
            height: 40px;
            padding: 0 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Unbounded', sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: #FFFFFF;
            background: #B0251A;
            border: none;
            border-radius: 6px;
            gap: 8px;
            text-decoration: none;
        }
        .btn-sign-out:hover {
            background: #8e1f16;
            color: #FFFFFF;
        }
        .btn-sign-out .icon {
            width: 16px;
            height: 16px;
            fill: #FFFFFF;
        }

        /* Main Layout Grid */
        .app-layout {
            display: flex;
            flex: 1;
        }

        /* --- MODIFIED: Left Panel CSS --- */
        .left-panel {
            width: 254px;
            min-height: calc(100vh - 64px - 52px);
            padding: 24px 16px;
            box-sizing: border-box;
            flex-shrink: 0;
            
            background-image: 
                linear-gradient(180deg, rgba(243, 244, 246, 0.9) 0%, rgba(229, 231, 235, 0.9) 100%), 
                url('@Url.Content("~/images/left_panel_background.png")');

            background-position: center, center;
            background-repeat: no-repeat, no-repeat;
            /* Gradient covers area, image is also set to cover to fill the width */
            background-size: cover, cover; 
        }

        .admin-panel-text {
            font-family: 'Unbounded', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #565D6D;
            margin-bottom: 20px;
            padding-left: 8px;
        }

        .panel-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .panel-menu-item a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px;
            text-decoration: none;
            border-radius: 6px;
            font-family: 'Unbounded', sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: #565D6D;
        }
        .panel-menu-item a:hover {
            background-color: rgba(224, 226, 231, 0.8);
        }

        .panel-menu-item a.selected {
            background: #FFFFFF;
            color: #1E2128;
        }

        .panel-menu-item a .icon {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

        /* Main Content Area */
        .main-content {
            flex: 1;
            padding: 30px 45px;
            overflow-y: auto;
        }

        /* Footer */
        .app-footer {
            width: 100%;
            height: 52px;
            background: #FFFFFF;
            box-shadow: 0px -1px 2px rgba(0, 0, 0, 0.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 45px;
            box-sizing: border-box;
            flex-shrink: 0;
        }

        .footer-text {
            font-family: 'Unbounded', sans-serif;
            font-size: 14px;
            color: #171A1F;
        }
        .footer-text a {
            color: #104387;
            text-decoration: none;
        }
        .footer-text a:hover {
            text-decoration: underline;
        }

        .footer-social-icons {
            display: flex;
            gap: 20px;
        }
        .footer-social-icons .icon {
            width: 20px;
            height: 20px;
            fill: #171A1F;
            transition: fill 0.2s ease;
        }
        .footer-social-icons a:hover .icon {
            fill: #104387;
        }

    </style>
</head>
<body>
    <header class="app-header">
        <div class="header-left-section">
            <img src="~/images/white_logo.png" alt="VeriWork_Admin Logo" class="dashboard-header-logo" />
            <!-- --- MODIFIED: Header Menu HTML --- -->
            <nav class="header-menu">
                <span class="header-brand-name">VeriWork</span>
            </nav>
        </div>
        <a class="btn-sign-out" asp-controller="User" asp-action="Login">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 2h8A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 5 12.5v-2a.5.5 0 0 1 1 0z" />
                <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708z" />
            </svg>
            Logout
        </a>
    </header>

    <div class="app-layout">
        <nav class="left-panel">
            <h6 class="admin-panel-text">ADMIN PANEL</h6>
            <ul class="panel-menu">
                <li class="panel-menu-item">
                    <a class="selected" asp-controller="User" asp-action="Dashboard">
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4M3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707M2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10m9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5m.754-4.246a.39.39 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.39.39 0 0 0-.029-.518z" />
                            <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A8 8 0 0 1 0 10m8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3" />
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li class="panel-menu-item">
                    <a asp-controller="Audit" asp-action="Index">
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="m14.12 10.163 1.715.858c.22.11.22.424 0 .534L8.267 15.34a.6.6 0 0 1-.534 0L.165 11.555a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0l5.317-2.66zM7.733.063a.6.6 0 0 1 .534 0l7.568 3.784a.3.3 0 0 1 0 .535L8.267 8.165a.6.6 0 0 1-.534 0L.165 4.382a.299.299 0 0 1 0-.535z" />
                            <path d="m14.12 6.576 1.715.858c.22.11.22.424 0 .534l-7.568 3.784a.6.6 0 0 1-.534 0L.165 7.968a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0z" />
                        </svg>
                        Audit Logs
                    </a>
                </li>
            </ul>
        </nav>

        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="footer-text">
            &copy; 2025 - VeriWork_Admin - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        <div class="footer-social-icons">
            <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951" />
            </svg></a>
            <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334q.002-.211-.006-.422A6.7 6.7 0 0 0 16 3.542a6.7 6.7 0 0 1-1.889.518 3.3 3.3 0 0 0 1.447-1.817 6.5 6.5 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.32 9.32 0 0 1-6.767-3.429 3.29 3.29 0 0 0 1.018 4.382A3.3 3.3 0 0 1 .64 6.575v.045a3.29 3.29 0 0 0 2.632 3.218 3.2 3.2 0 0 1-.865.115 3 3 0 0 1-.614-.057 3.28 3.28 0 0 0 3.067 2.277A6.6 6.6 0 0 1 .78 13.58a6 6 0 0 1-.78-.045A9.34 9.34 0 0 0 5.026 15" />
            </svg></a>
            <a href="#"><svg class="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334" />
            </svg></a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

