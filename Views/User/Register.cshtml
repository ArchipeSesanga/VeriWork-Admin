@model VeriWork_Admin.Application.Models.RegistrationModel

@{
    ViewData["Title"] = "Register New Employee";
    Layout = "_Layout";
}


<div class="register-page-container" id="mainContent">
    <form asp-action="Register" asp-controller="User" method="post" enctype="multipart/form-data" id="registerForm">

        <header class="page-header">
            <div>
                <h1>Register New Employee</h1>
                <p>Fill out the form below to add a new employee to your organization.</p>
            </div>
            <a asp-action="Dashboard" class="btn-register-employee">
                &leftarrow; Back to Dashboard
            </a>
        </header>

        <section class="form-section">
            <h2 class="form-section-title">Profile Photo</h2>
            <div class="photo-upload-container">
                <div class="avatar-preview">
                    <img id="avatarPreview" src="" alt="Avatar Preview" style="display:none;" />
                    <svg id="avatarPlaceholder" class="avatar-placeholder-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm8-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
                    </svg>
                </div>
                <label for="photoUpload" class="btn-upload">Upload Photo</label>
                <input asp-for="Photo" type="file" id="photoUpload" class="visually-hidden" accept="image/png, image/jpeg, image/gif" />
                <div class="upload-info">Supported file types: PNG, JPG, GIF. Max size: 5MB.</div>
                <span asp-validation-for="Photo"></span>
            </div>
        </section>

        <section class="form-section">
            <h2 class="form-section-title">Personal Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Name">First Name</label>
                    <input asp-for="Name" placeholder="e.g. John" />
                    <span asp-validation-for="Name"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Surname">Last Name</label>
                    <input asp-for="Surname" placeholder="e.g. Doe" />
                    <span asp-validation-for="Surname"></span>
                </div>
                <div class="form-group">
                    <label asp-for="IdNumber">SA ID/Passport number</label>
                    <input asp-for="IdNumber" placeholder="e.g. 0012314185081" />
                    <span asp-validation-for="IdNumber"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Gender">Gender</label>
                    
                    <select asp-for="Gender" class="form-control">
                        <option  value="">Select gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Prefer not say">Prefer not to say</option>
                    </select>
                    <span asp-validation-for="Gender"></span>
                </div>
            </div>
        </section>

        <section class="form-section">
            <h2 class="form-section-title">Employment Details</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="DepartmentId">Employee ID</label>
                    <input asp-for="DepartmentId" placeholder="e.g. EMP-001" />
                    <span asp-validation-for="DepartmentId"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Position">Job Title / Department</label>
                    <input asp-for="Position" placeholder="e.g. Software Engineer" />
                    <span asp-validation-for="Position"></span>
                </div>
                 <div class="form-group">
                    <label>Hire Date</label>
                    <input asp-for="HireDate" type="date" class="form-control" />
                    <span asp-validation-for="HireDate"></span>
                </div>
                 <div class="form-group">
                    <label>Role</label>
                    <select asp-for="Role" class="form-control">
                        <option value="" >Select Role</option>
                        <option value="Admin">Admin</option>
                        <option value="Employee">Employee</option>
                    </select>
                </div>
            </div>
        </section>

        <section class="form-section">
            <h2 class="form-section-title">Contact Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Email">Work Email</label>
                    <input asp-for="Email" placeholder="e.g. john.doe@company.com" />
                    <span asp-validation-for="Email"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone">Phone Number</label>
                    <input asp-for="Phone" placeholder="e.g. +27 (051) 123-4567" />
                    <span asp-validation-for="Phone"></span>
                </div>
                 <div class="form-group">
                    <label asp-for="EmergencyName">Emergency Contact Name</label>
                    <input asp-for="EmergencyName" class="form-control" placeholder="e.g. Jane Doe" />
                    <span asp-validation-for="EmergencyName"></span>
                </div>
                 <div class="form-group">
                    <label asp-for="EmergencyPhone">Emergency Contact Phone</label>
                    <input asp-for="EmergencyPhone" class="form-control" placeholder="e.g. +27 (012) 987-6543" />
                    <span asp-validation-for="EmergencyPhone"></span>
                </div>
            </div>
        </section>
        
        <section class="form-section">
            <h2 class="form-section-title">Address Details</h2>
            <div class="form-grid" style="grid-template-columns: 2fr 1fr;">
                 <div class="form-group">
                    <label asp-for="Address">Street Address</label>
                    <input asp-for="Address" placeholder="e.g. 123 Main St" />
                    <span asp-validation-for="Address"></span>
                </div>
                 <div class="form-group">
                    <label asp-for="City">City</label>
                    <input asp-for="City" class="form-control" placeholder="e.g. Anytown" />
                    <span asp-validation-for="City"></span>
                </div>
            </div>
             <div class="form-grid">
                 <div class="form-group">
                    <label asp-for="Province">Province</label>
                    <select asp-for="Province" class="form-control">
                        <option value="">Select Province</option>
                        <option value="Eastern Cape">Eastern Cape</option>
                        <option value="Free State">Free State</option>
                        <option value="Gauteng">Gauteng</option>
                        <option value="Kwazulu-Natal">KwaZulu-Natal</option>
                        <option value="Limpopo">Limpopo</option>
                        <option value="Mpumalanga">Mpumalanga</option>
                        <option value="North West">North West</option>
                        <option value="Nothern Cape">Northern Cape</option>
                        <option value="Western Cape">Western Cape</option>
                    </select>
                    <span asp-validation-for="Province"></span>
                </div>
                 <div class="form-group">
                    <label>Postal Code</label>
                    <input asp-for="PostalCode" class="form-control" placeholder="e.g. 90210" />
                    <span asp-validation-for="PostalCode"></span>
                </div>
                 <div class="form-group">
                     <label asp-for="Country">Country</label>
                     <select asp-for="Country" class="form-control">
                         <option value="">Select Country</option>
                         <option value="South Africa">South Africa</option>
                         <option value="Other">Other</option>
                     </select>
                     <span asp-validation-for="Country" class="text-danger"></span>
                 </div>

             </div>
        </section>

        <section class="form-section">
            <h2 class="form-section-title">Documents</h2>
            <div class="document-upload-container" id="documentUploadContainer">
                <svg class="upload-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5" />
                    <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z" />
                </svg>
                <p>Drag & Drop files here or click to upload</p>
                <div class="upload-info">Supported file types: PDF, DOCX, JPG, PNG. Max size: 5MB.</div>

                <input asp-for="Documents" type="file" id="documentInput" class="visually-hidden" multiple />
                <button type="button" class="btn-upload mt-3" id="uploadBtn">Upload Documents</button>
                <span asp-validation-for="Documents" class="text-danger"></span>
            </div>
        </section>

        <section class="form-section">
            <h2 class="form-section-title">Account Security</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="Enter password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
        </section>
        


        <div class="form-actions">
            <button type="reset" class="btn-download">Reset Form</button>
            <button type="submit" class="btn-register-employee">Submit Registration</button>
        </div>
    </form>
</div>

<div class="popup-overlay" id="popupOverlay">
    <div class="popup-box" id="successPopup" style="display:none;">        
        <svg class="popup-icon popup-icon-approve" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06l2.5 2.5a.75.75 0 0 0 1.06 0l5-5a.75.75 0 0 0 .022-1.08z"/>
        </svg>

        <h3 class="popup-title">Employee Registration Successful!</h3>
        <p class="popup-text">The new employee's profile has been created successfully.</p>
        
        <a id="viewProfileButton" href="#" class="btn-popup-action">View Employee Profile</a>
    </div>
</div>


@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ----- Document upload (Unchanged) -----
            const uploadBtn = document.getElementById('uploadBtn');
            const documentInput = document.getElementById('documentInput');
            const container = document.getElementById('documentUploadContainer');

            if (uploadBtn) {
                uploadBtn.addEventListener('click', () => documentInput.click());
            }
            if (container) {
                container.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    container.style.borderColor = '#104387';
                });
                container.addEventListener('dragleave', () => {
                    container.style.borderColor = '#DEE1E6';
                });
                container.addEventListener('drop', (e) => {
                    e.preventDefault();
                    documentInput.files = e.dataTransfer.files;
                    container.style.borderColor = '#DEE1E6';
                });
            }

            // ----- Profile photo preview (Unchanged) -----
            const photoUpload = document.getElementById('photoUpload');
            const avatarPreview = document.getElementById('avatarPreview');
            const avatarPlaceholder = document.getElementById('avatarPlaceholder');

            if (photoUpload) {
                photoUpload.addEventListener('change', function (event) {
                    const file = event.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            avatarPreview.src = e.target.result;
                            avatarPreview.style.display = 'block';
                            if(avatarPlaceholder) {
                                avatarPlaceholder.style.display = 'none';
                            }
                        }
                        reader.readAsDataURL(file);
                    }
                });
            }

            // ----- Form submission overlay logic (MODIFIED) -----
            const overlay = document.getElementById('popupOverlay');
            const mainContent = document.getElementById('mainContent');
            const $registerForm = $('#registerForm'); // Use jQuery selector

            if ($registerForm.length) {
                // This check ensures jQuery and the validator are loaded.
                if ($ && $.validator) {
                    
                    // Re-parse the form for unobtrusive validation to be safe
                    $registerForm.removeData("validator");
                    $registerForm.removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($registerForm);

                    // Get the validator's settings
                    var validator = $registerForm.data('validator');
                    if (validator) {
                        var settings = validator.settings;

                        // Store the original submit handler (if one exists)
                        const originalSubmitHandler = settings.submitHandler;

                        // This function will run ONLY if the form is VALID
                        settings.submitHandler = function(form, event) {
                            // Show overlay and blur background
                            if (overlay) {
                                overlay.style.display = 'flex';
                            }
                            if (mainContent) {
                                mainContent.classList.add('blurred');
                            }

                            // Now, either submit the form directly or call
                            // the original handler if it existed.
                            if (originalSubmitHandler) {
                                originalSubmitHandler.call(this, form, event);
                            } else {
                                // No original handler, just submit.
                                form.submit();
                            }
                        };

                        // This function will run if the form is INVALID
                        settings.invalidHandler = function(event, validator) {
                            // The form is invalid.
                            // jQuery Validate has already shown the red error messages.
                            // We do *nothing* here, so the screen does not blur.
                            console.log("Form invalid. Submission blocked. No blur.");
                        };
                    } else {
                         console.error("Could not find validator instance on form.");
                    }
                } else {
                    console.error("jQuery or jQuery Validate not loaded. Cannot attach popup logic.");
                }
            }
        });
    </script>
}
