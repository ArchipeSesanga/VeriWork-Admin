@model VeriWork_Admin.Application.Models.RegistrationModel

@{
    ViewData["Title"] = "Register New Employee";
    Layout = "_Layout";
}

<style>
    .register-page-container {
        font-family: 'Inter', sans-serif;
     /* max-width: 896px; */
        margin: 2rem auto;
        background: #FFFFFF;
        border-radius: 10px;
        padding: 56px;
        box-shadow: 0px 0px 1px rgba(23, 26, 31, 0.07), 0px 0px 2px rgba(23, 26, 31, 0.12);
    }

    /* Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 48px;
    }
    .page-header h1 {
        font-family: 'Unbounded', sans-serif;
        font-size: 30px;
        font-weight: 700;
        color: #171A1F;
        margin: 0;
    }
    .page-header p {
        font-size: 14px;
        color: #565D6D;
        margin-top: 8px;
    }
    .btn-back {
        height: 40px;
        padding: 0 16px;
        background: rgba(16, 67, 135, 0.7);
        color: #FFFFFF;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* Form Sections */
    .form-section {
        margin-bottom: 48px;
    }
    .form-section-title {
        font-family: 'Unbounded', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #171A1F;
        margin-bottom: 20px;
    }

    /* Profile Photo Upload */
    .photo-upload-container {
        text-align: center;
        background: #FAFAFB;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        padding: 25px;
    }
    .avatar-preview {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: #FFFFFF;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        overflow: hidden;
    }
    .avatar-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .avatar-placeholder-icon {
        width: 60px;
        height: 60px;
        color: #9095A1;
    }
    .btn-upload {
        font-family: 'Inter', sans-serif;
        color: #104387;
        background: #FFFFFF;
        border: 1px solid #104387;
        border-radius: 6px;
        padding: 8px 16px;
        cursor: pointer;
    }
    .upload-info {
        font-size: 12px;
        color: #565D6D;
        margin-top: 8px;
    }

    /* Form Grid Layout */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px 28px;
    }

    /* Form Group (Label, Input, Error) */
    .form-group {
        display: flex;
        flex-direction: column;
    }
    .form-group label {
        font-size: 14px;
        font-weight: 500;
        color: #171A1F;
        margin-bottom: 8px;
    }
    .form-group input, .form-group select {
        height: 49px;
        padding: 0 12px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        border: 1px solid #DEE1E6;
        border-radius: 6px;
        background: #FFFFFF;
    }
    .form-group input:focus, .form-group select:focus {
        outline: none;
        border-color: #104387;
        box-shadow: 0 0 0 2px rgba(16, 67, 135, 0.2);
    }
    
    /* --- Validation Error Styling --- */
    .form-group .input-validation-error {
        border-color: #DC2626; /* Red border for error */
    }
    .form-group .field-validation-error {
        color: #DC2626; /* Red text for error message */
        font-size: 12px;
        margin-top: 4px;
    }
    
    /* Document Upload */
    .document-upload-container {
        text-align: center;
        border: 2px dashed #DEE1E6;
        border-radius: 6px;
        padding: 40px;
    }
    .document-upload-container .upload-icon {
        color: #565D6D;
        width: 40px;
        height: 40px;
        margin-bottom: 12px;
    }
    .document-upload-container p {
        margin: 0;
        font-size: 16px;
        font-weight: 500;
        color: #565D6D;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 48px;
        border-top: 1px solid #DEE1E6;
        padding-top: 24px;
    }
    .btn-form {
        height: 40px;
        padding: 0 24px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
    }
    .btn-reset {
        background: #FFFFFF;
        border: 1px solid #DEE1E6;
        color: #565D6D;
    }
    .btn-submit {
        background: #104387;
        border: none;
        color: #FFFFFF;
    }
</style>

<div class="register-page-container">
    <form asp-action="Register" asp-controller="User" method="post" enctype="multipart/form-data">

        <header class="page-header">
            <div>
                <h1>Register New Employee</h1>
                <p>Fill out the form below to add a new employee to your organization.</p>
            </div>
            <a asp-action="Dashboard" class="btn-back">
                &leftarrow; Back to Directory
            </a>
        </header>

        <!-- Profile Photo Section -->
        <section class="form-section">
            <h2 class="form-section-title">Profile Photo</h2>
            <div class="photo-upload-container">
                <div class="avatar-preview">
                    <img id="avatarPreview" src="" alt="Avatar Preview" style="display:none;" />
                    <svg id="avatarPlaceholder" class="avatar-placeholder-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm8-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
                    </svg>
                </div>
                <label for="photoUpload" class="btn-upload">Upload Photo</label>
                <input asp-for="Photo" type="file" id="photoUpload" class="visually-hidden" accept="image/png, image/jpeg, image/gif" />
                <div class="upload-info">Supported file types: PNG, JPG, GIF. Max size: 5MB.</div>
                <span asp-validation-for="Photo"></span>
            </div>
        </section>

        <!-- Personal Information Section -->
        <section class="form-section">
            <h2 class="form-section-title">Personal Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Name">First Name</label>
                    <input asp-for="Name" placeholder="e.g. John" />
                    <span asp-validation-for="Name"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Surname">Last Name</label>
                    <input asp-for="Surname" placeholder="e.g. Doe" />
                    <span asp-validation-for="Surname"></span>
                </div>
                <div class="form-group">
                    <label asp-for="IdNumber">SA ID/Passport number</label>
                    <input asp-for="IdNumber" placeholder="e.g. 0012314185081" />
                    <span asp-validation-for="IdNumber"></span>
                </div>
                <div class="form-group">
                    <label>Gender</label>
                    <select class="form-control">
                        <option>Select gender</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Prefer not to say</option>
                    </select>
                </div>
            </div>
        </section>

        <!-- Employment Details Section -->
        <section class="form-section">
            <h2 class="form-section-title">Employment Details</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="DepartmentId">Employee ID</label>
                    <input asp-for="DepartmentId" placeholder="e.g. EMP-001" />
                    <span asp-validation-for="DepartmentId"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Position">Job Title / Department</label>
                    <input asp-for="Position" placeholder="e.g. Software Engineer" />
                    <span asp-validation-for="Position"></span>
                </div>
                 <div class="form-group">
                    <label>Hire Date</label>
                    <input type="date" class="form-control" />
                </div>
                 <div class="form-group">
                    <label>Manager</label>
                    <select class="form-control">
                        <option>Select manager</option>
                        <option>Jane Smith</option>
                    </select>
                </div>
            </div>
        </section>

        <!-- Contact Information -->
        <section class="form-section">
            <h2 class="form-section-title">Contact Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Email">Work Email</label>
                    <input asp-for="Email" placeholder="e.g. john.doe@company.com" />
                    <span asp-validation-for="Email"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone">Phone Number</label>
                    <input asp-for="Phone" placeholder="e.g. +27 (051) 123-4567" />
                    <span asp-validation-for="Phone"></span>
                </div>
                 <div class="form-group">
                    <label>Emergency Contact Name</label>
                    <input class="form-control" placeholder="e.g. Jane Doe" />
                </div>
                 <div class="form-group">
                    <label>Emergency Contact Phone</label>
                    <input class="form-control" placeholder="e.g. +27 (012) 987-6543" />
                </div>
            </div>
        </section>
        
        <!-- Address Details -->
        <section class="form-section">
            <h2 class="form-section-title">Address Details</h2>
            <div class="form-grid" style="grid-template-columns: 2fr 1fr;">
                 <div class="form-group">
                    <label asp-for="Address">Street Address</label>
                    <input asp-for="Address" placeholder="e.g. 123 Main St" />
                    <span asp-validation-for="Address"></span>
                </div>
                 <div class="form-group">
                    <label>City</label>
                    <input class="form-control" placeholder="e.g. Anytown" />
                </div>
            </div>
             <div class="form-grid">
                 <div class="form-group">
                    <label>Province</label>
                    <select class="form-control">
                    <option>Select Province</option>
                    <option>Eastern Cape</option>
                    <option>Free State</option>
                    <option>Gauteng</option>
                    <option>KwaZulu-Natal</option>
                    <option>Limpopo</option>
                    <option>Mpumalanga</option>
                    <option>North Wes</option>
                    <option>Northern Cape,</option>
                    <option>Western Cape</option>
                    </select>
                </div>
                 <div class="form-group">
                    <label>Postal Code</label>
                    <input class="form-control" placeholder="e.g. 90210" />
                </div>
                <div class="form-group">
                    <label>Country</label>
                    <select class="form-control">
                    <option>Select Country</option>
                    <option>South Africa</option>
                    <option>Other</option>
                    </select>
                </div>
            </div>
        </section>


        <!-- Documents Section -->
        <section class="form-section">
            <h2 class="form-section-title">Documents</h2>
            <div class="document-upload-container">
                <svg class="upload-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                  <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
                </svg>
                <p>Drag & Drop files here or click to upload</p>
                 <div class="upload-info">Supported file types: PDF, DOCX, JPG, PNG. Max size: 5MB.</div>
                 <button type="button" class="btn-upload mt-3">Upload Documents</button>
            </div>
        </section>

        <div class="form-actions">
            <button type="reset" class="btn-form btn-reset">Reset Form</button>
            <button type="submit" class="btn-form btn-submit">Submit Registration</button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const photoUpload = document.getElementById('photoUpload');
            const avatarPreview = document.getElementById('avatarPreview');
            const avatarPlaceholder = document.getElementById('avatarPlaceholder');

            photoUpload.addEventListener('change', function (event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        avatarPreview.src = e.target.result;
                        avatarPreview.style.display = 'block';
                        avatarPlaceholder.style.display = 'none';
                    }
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}
