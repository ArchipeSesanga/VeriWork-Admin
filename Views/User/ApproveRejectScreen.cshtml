@model VeriWork_Admin.Core.Entities.User

@{
    ViewData["Title"] = "Approve or Reject Employee";
    Layout = "_Layout";
}

<style>
    .verification-page-container {
        display: grid;
        grid-template-columns: 288px 1fr 370px; /* Defines the three-column layout */
        gap: 24px;
        padding: 2rem 0;
        font-family: 'Inter', sans-serif;
    }

    /* Shared Card Styling */
    .verification-card {
        background: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0px 0px 1px rgba(23, 26, 31, 0.07), 0px 1px 2px rgba(23, 26, 31, 0.12);
    }

    /* Left Column: Employee Profile Card */
    .profile-card {
        padding: 24px;
        text-align: center;
    }
    .avatar-container {
        position: relative;
        width: 131px;
        height: 131px;
        margin: 0 auto 16px;
    }
    .avatar-image {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }
    .online-indicator {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 33px;
        height: 33px;
        background-color: #65A30D;
        border: 2px solid white;
        border-radius: 50%;
    }
    .profile-card h4 {
        font-family: 'Unbounded', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #171A1F;
        margin-top: 1rem;
    }
    .profile-card p {
        font-size: 14px;
        color: #565D6D;
        margin: 4px 0 0 0;
    }

    /* Center Column: Documents */
    .documents-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }
    .documents-header h3 {
        font-family: 'Unbounded', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #171A1F;
        margin: 0;
    }
    .btn-back-profile {
        height: 40px;
        padding: 0 16px;
        background: rgba(16, 67, 135, 0.7);
        color: #FFFFFF;
        font-family: 'Unbounded', sans-serif;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .document-list-card {
        padding: 0;
    }
    .document-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .document-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #DEE1E6;
        font-size: 16px;
        font-weight: 600;
        color: #171A1F;
    }
    .document-item:last-child {
        border-bottom: none;
    }
    .document-status {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .status-tag {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 9999px;
    }
    .status-uploaded {
        background-color: #D1FAE5; /* Light Green */
        color: #065F46; /* Dark Green */
    }
    .status-pending {
        background-color: #FEF3C7; /* Light Yellow */
        color: #92400E; /* Dark Yellow */
    }
    .view-link {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #0F74C7;
        text-decoration: none;
    }
    .view-link:hover {
        text-decoration: underline;
    }

    /* Right Column: Final Decision */
    .decision-card {
        padding: 24px;
    }
    .decision-card h3 {
        font-family: 'Unbounded', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #171A1F;
        margin-bottom: 1rem;
    }
    .decision-card .form-label {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #565D6D;
    }
    .decision-card textarea {
        min-height: 120px;
        resize: vertical;
    }
    .decision-buttons {
        margin-top: 1.5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .btn-decision {
        height: 40px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 700;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }
    .btn-approve {
        color: #65A30D;
        background-color: #F7FEE7;
    }
    .btn-approve:hover {
        background-color: #ECFCCB;
    }
    .btn-reject {
        color: #FFFFFF;
        background-color: #DC2626;
    }
     .btn-reject:hover {
        background-color: #B91C1C;
    }
</style>

<div class="verification-page-container">
    
    <div class="verification-card profile-card">
        <div class="avatar-container">
            <img src="@(Model.PhotoUrl ?? "/images/user_profile.png")" alt="Employee Photo" class="avatar-image">
            <div class="online-indicator"></div>
        </div>
        <h4>@($"{Model.Name} {Model.Surname}")</h4>
        <p>Employee ID: @Model.IdNumber</p>
        <p>Department: Human Resources</p>
    </div>

    <div>
        <div class="documents-header">
            <h3>Uploaded Documents</h3>
            <a asp-controller="User" asp-action="EmployeeProfile" asp-route-idNumber="@Model.IdNumber" class="btn-back-profile">
                &leftarrow; Back to Profile
            </a>
        </div>
        <div class="verification-card document-list-card">
            <ul class="document-list">
                <li class="document-item">
                    <span>Proof of Identity/Passport</span>
                    <div class="document-status">
                        <span class="status-tag status-uploaded">Uploaded</span>
                        <a href="#" class="view-link">View</a>
                    </div>
                </li>
                <li class="document-item">
                    <span>Proof of Address</span>
                    <div class="document-status">
                        <span class="status-tag status-pending">Pending Review</span>
                        <a href="#" class="view-link">View</a>
                    </div>
                </li>
                <li class="document-item">
                    <span>Education Certificate</span>
                    <div class="document-status">
                        <span class="status-tag status-uploaded">Uploaded</span>
                        <a href="#" class="view-link">View</a>
                    </div>
                </li>
                <li class="document-item">
                    <span>Employment History (CV)</span>
                    <div class="document-status">
                        <span class="status-tag status-uploaded">Uploaded</span>
                        <a href="#" class="view-link">View</a>
                    </div>
                </li>
                <li class="document-item">
                    <span>Bank Statement</span>
                    <div class="document-status">
                        <span class="status-tag status-pending">Pending Review</span>
                        <a href="#" class="view-link">View</a>
                    </div>
                </li>
            </ul>
        </div>
    </div>

    <div class="verification-card decision-card">
        <h3>Final Decision</h3>
        <form>
            <div class="mb-3">
                <label for="adminNotes" class="form-label">Administrator Notes</label>
                <textarea class="form-control" id="adminNotes" rows="5" placeholder="Add any relevant notes here..."></textarea>
            </div>
            <div class="decision-buttons">
                 <button type="submit" class="btn-decision btn-approve">Approve Employee</button>
                 <button type="submit" class="btn-decision btn-reject">Reject Employee</button>
            </div>
        </form>
    </div>

</div>
