@* It's assumed this view will receive a single employee object, 
  so the model should be the User entity, not a List of them. 
*@
@model VeriWork_Admin.Core.Entities.User

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

@* Custom CSS for this specific page to achieve the desired look and feel *@
<style>
    body {
        background-color: #f8f9fa; /* A light grey background for the main content area */
    }

    .profile-card {
        text-align: center;
        padding: 2rem;
    }

    .profile-img-container {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 1rem;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .online-indicator {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 20px;
        height: 20px;
        background-color: #28a745; /* Green for online */
        border-radius: 50%;
        border: 2px solid white;
    }
    
    .document-list .list-group-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        font-weight: 500;
    }

    .decision-card .btn {
        width: 100%;
        margin-top: 0.5rem;
    }

</style>

<div class="container-fluid pt-4">
    <div class="row">

        <div class="col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body profile-card">
                    <div class="profile-img-container">
                        <img src="~/images/user_profile.png" alt="Employee Photo" class="rounded-circle profile-img">
                        <span class="online-indicator"></span>
                    </div>
                    <h4 class="card-title mt-3">@($"{Model.Name} {Model.Surname}")</h4>
                    <p class="text-muted mb-1">Employee ID: @Model.IdNumber</p>
                    <p class="text-muted">Department: Human Resources</p> @* Assuming Department name needs to be fetched *@
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="font-weight-bold mb-0">Uploaded Documents</h3>
                <a asp-controller="User" asp-action="Dashboard" class="btn btn-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                    </svg>
                    Back to Dashboard
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush document-list">
                        <li class="list-group-item">
                            <div>Proof of Identity/Passport</div>
                            <div>
                                <span class="badge bg-success me-3">Uploaded</span>
                                <a href="#" class="text-primary text-decoration-none">View</a>
                            </div>
                        </li>
                        <li class="list-group-item">
                            <div>Proof of Address</div>
                            <div>
                                <span class="badge bg-warning text-dark me-3">Pending Review</span>
                                <a href="#" class="text-primary text-decoration-none">View</a>
                            </div>
                        </li>
                        <li class="list-group-item">
                            <div>Education Certificate (Degree/Diploma)</div>
                             <div>
                                <span class="badge bg-success me-3">Uploaded</span>
                                <a href="#" class="text-primary text-decoration-none">View</a>
                            </div>
                        </li>
                        <li class="list-group-item">
                            <div>Employment History (CV)</div>
                             <div>
                                <span class="badge bg-success me-3">Uploaded</span>
                                <a href="#" class="text-primary text-decoration-none">View</a>
                            </div>
                        </li>
                        <li class="list-group-item">
                            <div>Bank Statement</div>
                             <div>
                                <span class="badge bg-warning text-dark me-3">Pending Review</span>
                                <a href="#" class="text-primary text-decoration-none">View</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
             <h3 class="font-weight-bold mb-3">Final Decision</h3>
             <div class="card shadow-sm border-0 decision-card">
                 <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label for="adminNotes" class="form-label text-muted">Administrator Notes</label>
                            <textarea class="form-control" id="adminNotes" rows="6" placeholder="Add any relevant notes here..."></textarea>
                        </div>
                        <div class="d-grid gap-2">
                             <button type="submit" class="btn btn-success">Approve Employee</button>
                             <button type="submit" class="btn btn-danger">Reject Employee</button>
                        </div>
                    </form>
                 </div>
             </div>
        </div>

    </div>
</div>