@model VeriWork_Admin.Application.Models.EditUserModel

@{
    ViewData["Title"] = "Update Employee Information";
    Layout = "_Layout";
}

<div class="edit-page-container" id="mainContent">
    <form asp-action="Edit" asp-controller="User" method="post" enctype="multipart/form-data" id="editForm">

        <!-- REQUIRED: Hidden UID field -->
        <input type="hidden" asp-for="Uid" />

        <header class="page-header">
            <div>
                <h1>Update Information</h1>
                <p>Edit the form below to update your employee information.</p>
            </div>
            <a asp-controller="User" asp-action="EmployeeProfile" asp-route-uid="@Model.Uid" class="btn-register-employee">
                &leftarrow; Back to Profile
            </a>
        </header>

        <!-- Hidden fields to preserve existing file URLs -->
        <input type="hidden" asp-for="PhotoUrl" />
        @if (Model.DocumentUrls != null && Model.DocumentUrls.Any())
        {
            @foreach (var url in Model.DocumentUrls)
            {
                <input type="hidden" name="DocumentUrls" value="@url" />
            }
        }

        <!-- PROFILE PHOTO -->
        <section class="form-section">
            <h2 class="form-section-title">Profile Photo</h2>
            <div class="photo-upload-container">
                <div class="avatar-preview">
                    <img id="avatarPreview" src="@Url.Content(Model.PhotoUrl ?? "~/images/default_avatar.png")" alt="Avatar Preview" />
                </div>
                <label for="photoUpload" class="btn-upload">Upload New Photo</label>
                <input asp-for="Photo" type="file" id="photoUpload" class="visually-hidden" accept="image/png, image/jpeg, image/gif" />
            </div>
        </section>

        <!-- PERSONAL INFORMATION -->
        <section class="form-section">
            <h2 class="form-section-title">Personal Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Name">First Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Surname">Last Name</label>
                    <input asp-for="Surname" class="form-control" />
                    <span asp-validation-for="Surname" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>Gender</label>
                    <select asp-for="Gender" class="form-control">
                        <option value="">Select gender</option>
                        <option>Female</option>
                        <option>Male</option>
                        <option>Prefer not to say</option>
                    </select>
                </div>
            </div>
        </section>

        <input type="hidden" asp-for="IdNumber" />

        <!-- EMPLOYMENT DETAILS -->
        <section class="form-section">
            <h2 class="form-section-title">Employment Details</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="IdNumber">Employee ID</label>
                    <input asp-for="IdNumber" readonly class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Position">Position</label>
                    <input asp-for="Position" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="DepartmentId">Department ID</label>
                    <input asp-for="DepartmentId" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Role">Role</label>
                    <select asp-for="Role" class="form-control">
                        <option value="">Select Role</option>
                        <option value="Admin">Admin</option>
                        <option value="Employee">Employee</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="HireDate">Hire Date</label>
                    <input asp-for="HireDate" type="date" class="form-control" />
                </div>
            </div>
        </section>

        <!-- CONTACT INFORMATION -->
        <section class="form-section">
            <h2 class="form-section-title">Contact Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EmergencyName">Emergency Contact Name</label>
                    <input asp-for="EmergencyName" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EmergencyPhone">Emergency Contact Phone</label>
                    <input asp-for="EmergencyPhone" class="form-control" />
                </div>
            </div>
        </section>

        <!-- ADDRESS DETAILS -->
        <section class="form-section">
            <h2 class="form-section-title">Address Details</h2>
            <div class="form-grid" style="grid-template-columns: 2fr 1fr;">
                <div class="form-group">
                    <label asp-for="Address">Street Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="City">City</label>
                    <input asp-for="City" class="form-control" />
                </div>
            </div>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Province">Province</label>
                    <input asp-for="Province" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="PostalCode">Postal Code</label>
                    <input asp-for="PostalCode" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Country">Country</label>
                    <input asp-for="Country" class="form-control" />
                </div>
            </div>
        </section>

        <!-- DOCUMENT UPLOAD -->
        <section class="form-section">
            <h2 class="form-section-title">Documents</h2>

            <!-- Show existing uploaded docs -->
            @if (Model.DocumentUrls != null && Model.DocumentUrls.Any())
            {
                <ul class="uploaded-docs-list">
                    @foreach (var docUrl in Model.DocumentUrls)
                    {
                        <li>
                            <a href="@docUrl" target="_blank">
                                📄 @System.IO.Path.GetFileName(docUrl)
                            </a>
                        </li>
                    }
                </ul>
            }

            <div class="document-upload-container mt-2">
                <p>Upload new files (optional)</p>
                <input asp-for="Documents" type="file" multiple class="form-control" accept=".pdf,.docx,.jpg,.png" />
                <span asp-validation-for="Documents" class="text-danger"></span>
            </div>
        </section>

        <!-- ACTION BUTTONS -->
        <div class="form-actions">
            <a asp-action="Dashboard" class="btn-download">Cancel</a>
            <button type="submit" class="btn-register-employee">Update Information</button>
        </div>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const photoUpload = document.getElementById('photoUpload');
            const avatarPreview = document.getElementById('avatarPreview');
            if (photoUpload) {
                photoUpload.addEventListener('change', function (event) {
                    const file = event.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            avatarPreview.src = e.target.result;
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }
        });
    </script>
}
