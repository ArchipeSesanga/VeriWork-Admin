@model System.Collections.Generic.List<VeriWork_Admin.Core.Entities.User>

@{
    ViewBag.Title = "Dashboard";
    Layout = "_Layout";
}

<head >
    <link rel="stylesheet" href="css/site.css"/>
    <title>Dashboard</title>
</head>
<div class="text-start">
    <h2 class="">Dashboard</h2>
</div>

<div class="text-start mt-4">
    <h3 class="font-weight-bold">Quick Actions</h3>
    <p>Perform common employee management tasks.</p>


    <div class="d-flex gap-2">
        <button class="btn btn-primary"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-bounding-box mx-2" viewBox="0 0 16 16">
                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5"/>
                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm8-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
            </svg> <a asp-controller="User" asp-action="Register" class="text-white">Register Employee</a>
        </button>
        <!-- Search -->
        <input class="form-control form-control-dark w-25"
               type="text"
               placeholder="🔍 Search for an employee"
               aria-label="Search">
    </div>


    <section class="mt-5">
        <div>
            <h4>Employee Directory</h4>
            <p class="text-muted">View and manage all employee records.</p>

            <table class="table table-hover align-middle">
                <thead class="thead-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Employee</th>
                    <th scope="col">ID</th>
                    <th scope="col">Department</th>
                    <th scope="col">Role</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
                </thead>
                <tbody>
                @if (Model != null && Model.Any())
                {
                    var index = 1;
                    foreach (var user in Model)
                    {
                        <tr>
                            <th scope="row">@index</th>
                            <td>@($"{user.Name} {user.Surname}")</td>
                            <td>@user.IdNumber</td>
                            <td>@user.DepartmentId</td>
                            <td>@user.Role</td>
                            <td>
                                <span class="badge bg-secondary">N/A</span> @* Status placeholder until implemented *@
                            </td>
                            <td>
                                <a asp-controller="User" 
                                   asp-action="EmployeeProfile" 
                                   asp-route-idNumber="@user.IdNumber"
                                   class="btn btn-sm btn-outline-primary">
                                    View Profile
                                </a>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">No employees found.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
