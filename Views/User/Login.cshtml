@model VeriWork_Admin.Core.Entities.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - VeriWork</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

    <style>
        /* General Body and Page Setup */
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        .page {
            position: relative;
            width: 100vw;
            height: 100vh;
            background: #F1F8FE;
            overflow: hidden;
        }

        /* Header */
        .login-header {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 64px;
            background: #104387;
        }

        .login-header-logo {
            position: absolute;
            top: 13px;
            left: 27px;
            width: 61px;
            height: 38px;
        }

        /* Form Container - Centered */
        .login-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 448px;
            height: auto;
            padding-bottom: 40px;
            background: #FFFFFF;
            border-radius: 10px;
            box-shadow: 0px 0px 1px #171a1fD, 0px 0px 2px #171a1f14;
        }
        
        /* Form Elements */
        .login-form {
            position: relative;
            width: 100%;
            padding: 0 56px;
            box-sizing: border-box;
            text-align: center;
        }

        .login-form-logo {
            margin-top: 51px;
            width: 107px;
            height: 78px;
        }

        .login-form-welcome-text {
            margin-top: 12px;
            font-family: 'Unbounded', sans-serif;
            font-size: 30px;
            line-height: 36px;
            font-weight: 700;
            color: #171A1F;
        }

        .login-form-welcome-subtext {
            margin-top: 12px;
            font-size: 16px;
            line-height: 24px;
            font-weight: 400;
            color: #565D6D;
        }

        /* Textbox Styling */
        .textbox {
            margin-top: 38px;
            text-align: left;
        }

        .textbox .label {
            display: block;
            margin-bottom: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 22px;
            font-weight: 500;
            color: #171A1F;
        }
        
        .textbox input {
            width: 100%;
            height: 40px;
            padding: 0 12px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            background: #FFFFFF;
            border-radius: 6px;
            border: 1px solid #DEE1E6; /* Default border color */
            outline: none;
            box-sizing: border-box;
        }

        /* --- NEW: Error Styling for Inputs --- */
        .textbox input.input-error {
            border-color: #DC2626; /* Red border for errors */
        }
        .textbox input.input-error:hover {
            border-color: #B51E1E;
        }
        .textbox input.input-error:focus {
            border-color: #DC2626;
        }
        
        /* --- NEW: Error Message Styling --- */
        .error-message {
            margin-top: 9px;
            text-align: left;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 20px;
            font-weight: 400;
            color: #DC2626; /* Red text color for errors */
        }

        /* Forgot Password Link */
        .forgot-password-text {
            display: block;
            margin-top: 9px;
            text-align: right;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 20px;
            font-weight: 400;
            color: #0F74C7;
            text-decoration: none;
        }
        .forgot-password-text:hover {
            text-decoration: underline;
        }

        /* Button Styling */
        .login-button {
            margin-top: 23px;
            width: 100%;
            height: 40px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: #FFFFFF;
            background: #0F74C7;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }
        .login-button:hover {
            background: #0A4D84;
        }

        /* Bottom Text */
        .login-form-bottom-text {
            margin-top: 41px;
            font-size: 12px;
            color: #565D6D;
        }
        .login-form-bottom-text a {
            color: #0F74C7;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="page">
        <header class="login-header">
            <img src="~/images/white_logo.png" alt="VeriWork Logo" class="login-header-logo" />
        </header>

        <div class="login-container">
            <form class="login-form" asp-controller="User" asp-action="Login" method="post">
                <img src="~/images/black_logo.png" class="login-form-logo" alt="Logo">
                
                <h1 class="login-form-welcome-text">Welcome to VeriWork</h1>
                
                <p class="login-form-welcome-subtext">Securely manage employee verification.</p>

                @{
                    // This variable will be used to apply the error class to the inputs
                    var errorClass = ViewData.ModelState.IsValid ? "" : "input-error";
                }

                <div class="textbox">
                    <label asp-for="Email" class="label">Email or Username</label>
                    <input asp-for="Email" class="@errorClass" placeholder="Enter your email" required autofocus>
                </div>

                <div class="textbox">
                    <label for="Password" class="label">Password</label>
                    <input id="Password" name="Password" type="password" class="@errorClass" placeholder="Enter your password" required>
                </div>
                
                <!-- --- NEW: Error Message Display --- -->
                <!-- This will only appear if an error is sent from the controller -->
                <div asp-validation-summary="ModelOnly" class="error-message"></div>

                <a href="#" class="forgot-password-text">Forgot Password?</a>

                <button class="login-button" type="submit">Sign in</button>

                <p class="login-form-bottom-text">
                    By clicking “Sign in”, you agree to our <a href="#">Terms of Use</a> and our <a href="#">Privacy Policy</a>.
                </p>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

</body>
</html>